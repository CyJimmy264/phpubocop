#!/usr/bin/env php
<?php

declare(strict_types=1);

use PHPuboCop\Application;

if (shouldRestartWithoutXdebug()) {
    exit(restartWithoutXdebug($argv));
}

$autoloadCandidates = [
    __DIR__ . '/../vendor/autoload.php',
    __DIR__ . '/../../../autoload.php',
];

$autoloadPath = null;
foreach ($autoloadCandidates as $candidate) {
    if (is_file($candidate)) {
        $autoloadPath = $candidate;
        break;
    }
}

if ($autoloadPath === null) {
    fwrite(STDERR, "Unable to locate Composer autoload.php\n");
    exit(1);
}

require_once $autoloadPath;

// Large legacy codebases can require substantial memory for AST parsing.
$memoryLimit = getenv('PHPUBOCOP_MEMORY_LIMIT') ?: '8G';
ini_set('memory_limit', $memoryLimit);

$app = new Application();
exit($app->run($argv));

function shouldRestartWithoutXdebug(): bool
{
    if (PHP_SAPI !== 'cli') {
        return false;
    }
    if (!extension_loaded('xdebug')) {
        return false;
    }
    if (getenv('PHPUBOCOP_ALLOW_XDEBUG') === '1') {
        return false;
    }
    if (getenv('PHPUBOCOP_XDEBUG_DISABLED') === '1') {
        return false;
    }

    return true;
}

/** @param list<string> $argv */
function restartWithoutXdebug(array $argv): int
{
    $phpBinary = PHP_BINARY;
    $command = escapeshellarg($phpBinary) . ' -d xdebug.mode=off';
    foreach ($argv as $arg) {
        $command .= ' ' . escapeshellarg($arg);
    }

    putenv('PHPUBOCOP_XDEBUG_DISABLED=1');
    passthru($command, $exitCode);
    return $exitCode;
}

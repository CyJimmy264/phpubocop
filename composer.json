{
  "name": "mveynberg/phpubocop",
  "version": "0.1.0",
  "description": "RuboCop-inspired style and lint checker for PHP",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "nikic/php-parser": "^5.0",
    "symfony/yaml": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "PHPuboCop\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PHPuboCop\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/phpubocop"
  ],
  "scripts": {
    "test": "phpunit"
  }
}
